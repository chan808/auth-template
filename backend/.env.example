# Copy this file to .env and fill in your local values.
# This file is loaded by Spring Boot via `spring.config.import`
# and by Docker Compose via `env_file`.

# MySQL
DB_URL=jdbc:mysql://localhost:3306/authtemplate?serverTimezone=Asia/Seoul&characterEncoding=UTF-8&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_ROOT_PASSWORD=replace-me-root-password
MYSQL_DATABASE=authtemplate
MYSQL_USER=replace-me-db-user
MYSQL_PASSWORD=replace-me-db-password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=replace-me-redis-password

# Minio
MINIO_ROOT_USER=replace-me-minio-user
MINIO_ROOT_PASSWORD=replace-me-minio-password

# JWT
JWT_SECRET=replace-me-with-a-long-random-secret-at-least-32-bytes

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-email@example.com

# App
APP_BASE_URL=http://localhost:3000
APP_DEFAULT_LOCALE=ko
APP_NAME=auth-template
CORS_ALLOWED_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
SWAGGER_ENABLED=true

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
